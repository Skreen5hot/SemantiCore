{
  "name": "semanticore",
  "version": "0.1.0",
  "description": "Edge-canonical semantic enrichment workbench for structured data using TagTeam.js and JSON-LD",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/kernel/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:tests": "tsc -p tsconfig.test.json",
    "start": "node dist/index.js",
    "test": "npm run build:tests && node dist-tests/tests/run-tests.js",
    "test:purity": "npm run build:tests && node dist-tests/scripts/ensure-kernel-purity.js",
    "clean": "rimraf dist dist-tests"
  },
  "keywords": [
    "semanticore",
    "tagteam",
    "semantic-enrichment",
    "json-ld",
    "deterministic",
    "edge-computing",
    "offline-first"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Skreen5hot/SemantiCore.git"
  },
  "homepage": "https://skreen5hot.github.io/SemantiCore/",
  "author": "Aaron Damiano",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^25.8.0",
    "rimraf": "^6.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
